/* ============================================
   物品详情页样式 - 高端沉浸式体验 v3.0
   ============================================ */

/* 动画关键帧 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.05); opacity: 0.8; }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes heartBeat {
  0%, 100% { transform: scale(1); }
  14% { transform: scale(1.3); }
  28% { transform: scale(1); }
  42% { transform: scale(1.3); }
  70% { transform: scale(1); }
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* 渐变色定义 */
.gradient-1 { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.gradient-2 { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
.gradient-3 { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
.gradient-4 { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
.gradient-5 { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }

/* 页面容器 */
.detail-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ========== 沉浸式图片画廊 ========== */
.gallery-section {
  position: relative;
  padding: 20rpx 0;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
}

.gallery-swiper {
  height: 560rpx;
}

.gallery-item {
  padding: 0 10rpx;
  box-sizing: border-box;
}

.gallery-image-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.gallery-image {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}

.gallery-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.4), transparent);
  border-radius: 0 0 24rpx 24rpx;
}

.gallery-indicator {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 20rpx;
}

.indicator-dot {
  width: 8rpx;
  height: 8rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 4rpx;
  transition: all 0.3s ease;
}

.indicator-dot.active {
  width: 24rpx;
  background: #fff;
}

.gallery-badge {
  position: absolute;
  bottom: 40rpx;
  right: 50rpx;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.badge-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
}

/* ========== 内容区域 ========== */
.content-wrapper {
  padding: 0 30rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 10;
}

/* 通用卡片样式 */
.info-card,
.section-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  animation: fadeInUp 0.6s ease-out forwards;
  opacity: 0;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

/* ========== 物品信息卡片 ========== */
.info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.tag-group {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-condition {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #92400e;
}

.tag-icon {
  font-size: 22rpx;
}

.tag-category {
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  color: #4338ca;
}

.favorite-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.favorite-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f4f6;
  border-radius: 50%;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.favorite-btn.active {
  background: linear-gradient(135deg, #fecaca 0%, #fca5a5 100%);
  animation: heartBeat 0.6s ease;
}

.favorite-btn:active {
  transform: scale(0.9);
}

.favorite-icon {
  font-size: 36rpx;
}

.favorite-count {
  font-size: 22rpx;
  color: #9ca3af;
}

.item-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.4;
  margin-bottom: 28rpx;
}

/* 价格区域 */
.price-section {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fef2f2 0%, #fdf2f8 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.price-main {
  flex: 1;
}

.price-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.price-value {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 32rpx;
  font-weight: 700;
  color: #dc2626;
  margin-right: 4rpx;
}

.price-number {
  font-size: 56rpx;
  font-weight: 800;
  color: #dc2626;
  letter-spacing: -1rpx;
}

.price-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(0, 0, 0, 0.08);
  margin: 0 32rpx;
}

.price-original {
  text-align: center;
}

.original-label {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.original-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #9ca3af;
  text-decoration: line-through;
}

/* 元信息 */
.meta-section {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f3f4f6;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.meta-icon {
  font-size: 26rpx;
}

/* ========== 区块卡片通用样式 ========== */
.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.section-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.section-icon {
  font-size: 28rpx;
  color: #fff;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

/* 换物需求卡片 */
.exchange-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.exchange-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.exchange-label {
  font-size: 26rpx;
  color: #6b7280;
  width: 140rpx;
  flex-shrink: 0;
}

.exchange-type-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.exchange-type-badge.specific {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  color: #1d4ed8;
}

.exchange-type-badge.any {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #047857;
}

.exchange-value {
  font-size: 26rpx;
  color: #374151;
  font-weight: 500;
  flex: 1;
}

.exchange-value.highlight {
  color: #dc2626;
  font-weight: 700;
}

/* 成色描述卡片 */
.condition-content {
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 24rpx;
}

.condition-text {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.8;
}

/* AI智能分析卡片 */
.ai-card {
  background: linear-gradient(135deg, #ede9fe 0%, #e0e7ff 100%);
  border: 1rpx solid rgba(99, 102, 241, 0.1);
}

.ai-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.ai-title-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ai-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: float 3s ease-in-out infinite;
}

.ai-icon {
  font-size: 28rpx;
}

.ai-title-text {
  display: flex;
  flex-direction: column;
}

.ai-main-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.ai-subtitle {
  font-size: 22rpx;
  color: #6b7280;
}

.ai-badge {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.ai-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ai-features {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.feature-tag {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.feature-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.feature-value {
  font-size: 26rpx;
  color: #4f46e5;
  font-weight: 600;
}

.ai-description {
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.7;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 发布者卡片 */
.owner-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 8rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.owner-content:active {
  background: #f9fafb;
}

.owner-avatar-wrapper {
  position: relative;
}

.owner-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.owner-verify-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 32rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}

.owner-verify-badge text {
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
}

.owner-info {
  flex: 1;
}

.owner-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.owner-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.owner-school {
  font-size: 24rpx;
  color: #6b7280;
}

.owner-verify-text {
  font-size: 22rpx;
  color: #10b981;
  font-weight: 500;
}

.owner-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
  font-size: 36rpx;
}

/* 推荐匹配区域 */
.matches-section {
  margin-bottom: 24rpx;
  animation: fadeInUp 0.6s ease-out forwards;
  opacity: 0;
}

.matches-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.matches-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.matches-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  color: #6366f1;
  font-weight: 500;
}

.more-arrow {
  font-size: 32rpx;
}

.matches-scroll {
  width: 100%;
}

.matches-list {
  display: flex;
  gap: 20rpx;
  padding: 8rpx 4rpx 24rpx;
}

.match-item {
  flex-shrink: 0;
  width: 240rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.match-item:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.match-image-wrapper {
  width: 100%;
  height: 180rpx;
  overflow: hidden;
}

.match-image {
  width: 100%;
  height: 100%;
}

.match-title {
  display: block;
  font-size: 26rpx;
  color: #374151;
  font-weight: 500;
  padding: 16rpx 16rpx 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.match-price {
  display: block;
  font-size: 28rpx;
  color: #dc2626;
  font-weight: 700;
  padding: 0 16rpx 16rpx;
}

.safe-area-bottom {
  height: 40rpx;
}

/* ========== 底部操作栏 ========== */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 -4rpx 30rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.action-group {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.action-btn:active {
  background: #f3f4f6;
}

.action-icon-wrapper {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  border-radius: 14rpx;
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 22rpx;
  color: #6b7280;
}

.action-divider {
  width: 2rpx;
  height: 48rpx;
  background: #e5e7eb;
}

.exchange-action {
  flex: 1;
}

.exchange-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.exchange-btn.disabled {
  background: #d1d5db;
  box-shadow: none;
}

.exchange-btn:active:not(.disabled) {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.exchange-icon {
  font-size: 32rpx;
}

.exchange-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}
