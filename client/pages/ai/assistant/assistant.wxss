/* ============================================
   AI客服页面样式 - 现代聊天界面 v3.0
   ============================================ */

/* 动画关键帧 */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-8rpx); }
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 页面容器 */
.assistant-container {
  height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  display: flex;
  flex-direction: column;
  position: relative;
}

/* ========== 头部 ========== */
.header {
  position: relative;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  padding-top: calc(40rpx + env(safe-area-inset-top));
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 20% 50%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 50%, rgba(255, 255, 255, 0.1) 0%, transparent 50%);
}

.header-content {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.ai-avatar {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.avatar-icon {
  font-size: 48rpx;
  animation: float 3s ease-in-out infinite;
}

.status-dot {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 20rpx;
  height: 20rpx;
  background: #22c55e;
  border-radius: 50%;
  border: 3rpx solid #667eea;
  animation: pulse 2s ease-in-out infinite;
}

.header-info {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-status {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ========== 消息列表 ========== */
.message-list {
  flex: 1;
  padding: 30rpx;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
  animation: fadeIn 0.3s ease-out;
}

.message-item.ai {
  flex-direction: row;
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  flex-shrink: 0;
  margin: 0 16rpx;
}

.avatar-bg {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: 600;
}

.avatar-bg.ai {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.avatar-bg.user {
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  color: #4338ca;
}

.message-content {
  max-width: 70%;
  display: flex;
  flex-direction: column;
}

.message-item.ai .message-content {
  align-items: flex-start;
}

.message-item.user .message-content {
  align-items: flex-end;
}

.message-bubble {
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-wrap: break-word;
  max-width: 100%;
}

.message-bubble.ai {
  background: #fff;
  color: #1f2937;
  border-top-left-radius: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  animation: slideInLeft 0.3s ease-out;
}

.message-bubble.user {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-top-right-radius: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
  animation: slideInRight 0.3s ease-out;
}

.message-text {
  white-space: pre-wrap;
}

/* 流式回复光标 */
.typing-cursor {
  display: inline-block;
  color: #667eea;
  font-weight: 300;
  margin-left: 2rpx;
  animation: cursorBlink 0.8s ease-in-out infinite;
}

@keyframes cursorBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

.message-time {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

/* 正在输入动画 */
.typing-indicator {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  border-top-left-radius: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.typing-dot {
  width: 14rpx;
  height: 14rpx;
  background: #cbd5e1;
  border-radius: 50%;
  animation: typing 1.4s infinite;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

/* ========== 快捷问题 ========== */
.quick-section {
  padding: 0 30rpx 30rpx;
}

.quick-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.quick-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #e2e8f0, transparent);
}

.quick-title {
  font-size: 26rpx;
  color: #64748b;
  white-space: nowrap;
}

.quick-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quick-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  border: 2rpx solid transparent;
}

.quick-card:active {
  transform: translateX(8rpx);
  border-color: #667eea;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.15);
}

.quick-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  border-radius: 14rpx;
  font-size: 28rpx;
}

.quick-text {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
}

/* ========== 输入框 ========== */
.input-section {
  background: #fff;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 30rpx rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
  position: relative;
  z-index: 100;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f1f5f9;
  border-radius: 40rpx;
  padding: 8rpx 8rpx 8rpx 24rpx;
  transition: all 0.3s ease;
}

.input-box:focus-within {
  background: #e2e8f0;
}

.message-input {
  flex: 1;
  height: 72rpx;
  font-size: 30rpx;
  color: #1f2937;
}

.input-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.action-icon:active {
  transform: scale(0.9);
  background: #f8fafc;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e2e8f0;
  border-radius: 50%;
  border: none;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.send-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.send-btn:active.active {
  transform: scale(0.9);
}

.send-icon {
  font-size: 32rpx;
  color: #fff;
  margin-left: 4rpx;
}
