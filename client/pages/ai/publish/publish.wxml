<view class="ai-publish-container">
  <!-- 动态背景 -->
  <view class="dynamic-bg">
    <view class="bg-gradient"></view>
    <view class="bg-pattern"></view>
  </view>

  <!-- 头部 -->
  <view class="header-section">
    <view class="ai-avatar-container">
      <view class="ai-avatar">
        <text class="avatar-icon">🤖</text>
      </view>
      <view class="avatar-ring r1"></view>
      <view class="avatar-ring r2"></view>
    </view>
    <view class="header-text">
      <text class="header-title">AI 智能发布</text>
      <text class="header-subtitle">说话就能发布，AI帮你完善信息</text>
    </view>
  </view>

  <!-- 输入区 -->
  <view class="input-section" wx:if="{{!showResult}}">
    <view class="input-card">
      <view class="input-header">
        <view class="input-icon">💬</view>
        <text class="input-title">描述你的物品</text>
      </view>
      <view class="input-area">
        <textarea
          class="desc-input"
          placeholder="例如：我有个用了半年的iPad Pro 11寸，128G，银色，保护得很好，想换个相机..."
          value="{{inputText}}"
          bindinput="onInputChange"
          maxlength="500"
          auto-height
        />
        <view class="input-footer">
          <view class="voice-btn" bindtap="startVoiceInput">
            <text class="voice-icon">🎤</text>
            <text>语音输入</text>
          </view>
          <text class="char-count">{{inputText.length || 0}}/500</text>
        </view>
      </view>
    </view>

    <!-- 快捷示例 -->
    <view class="examples-section">
      <view class="examples-header">
        <view class="examples-line"></view>
        <text class="examples-title">💡 试试这些例子</text>
        <view class="examples-line"></view>
      </view>
      <view class="examples-grid">
        <view class="example-card" bindtap="fillExample" data-example="全新未拆封的AirPods Pro 2代，教育优惠买的，想换机械键盘">
          <view class="example-icon">🎧</view>
          <view class="example-content">
            <text class="example-title">全新AirPods换键盘</text>
            <text class="example-desc">电子产品 · 全新</text>
          </view>
        </view>
        <view class="example-card" bindtap="fillExample" data-example="考研数学全书，李永乐版，只写过几页，九成新">
          <view class="example-icon">📚</view>
          <view class="example-content">
            <text class="example-title">考研书</text>
            <text class="example-desc">图书教材 · 九成新</text>
          </view>
        </view>
        <view class="example-card" bindtap="fillExample" data-example="宿舍用小冰箱，美的品牌，用了两年，功能正常，想换显示器">
          <view class="example-icon">❄️</view>
          <view class="example-content">
            <text class="example-title">小冰箱换显示器</text>
            <text class="example-desc">生活电器 · 八成新</text>
          </view>
        </view>
      </view>
    </view>

    <!-- AI解析按钮 -->
    <view class="action-section">
      <button 
        class="ai-parse-btn {{inputText ? 'active' : ''}}" 
        bindtap="parseItem"
        loading="{{isParsing}}"
        disabled="{{isParsing || !inputText}}"
      >
        <view class="btn-glow"></view>
        <view class="btn-content" wx:if="{{!isParsing}}">
          <view class="btn-icon-wrapper">
            <text class="btn-icon">✨</text>
          </view>
          <text class="btn-text">AI智能解析</text>
        </view>
        <view class="btn-loading" wx:else>
          <view class="loading-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
          <text class="loading-text">AI思考中...</text>
        </view>
      </button>
    </view>
  </view>

  <!-- 解析结果 -->
  <view class="result-section" wx:if="{{showResult && parsedItem}}">
    <view class="result-card">
      <view class="result-header">
        <view class="success-badge">
          <text class="badge-icon">✓</text>
          <text>解析成功</text>
        </view>
        <view class="confidence-score" wx:if="{{parsedItem.confidence}}">
          <text class="score-value">{{parsedItem.confidence}}%</text>
          <text class="score-label">匹配度</text>
        </view>
      </view>

      <view class="result-content">
        <!-- 物品名称 -->
        <view class="result-field">
          <view class="field-label">
            <text class="label-icon">📦</text>
            <text>物品名称</text>
          </view>
          <view class="field-value highlight">
            <text>{{parsedItem.title}}</text>
          </view>
        </view>

        <!-- 详细描述 -->
        <view class="result-field">
          <view class="field-label">
            <text class="label-icon">📝</text>
            <text>详细描述</text>
          </view>
          <view class="field-value description">
            <text>{{parsedItem.description}}</text>
          </view>
        </view>

        <!-- 分类和成色 -->
        <view class="result-row">
          <view class="result-field half">
            <view class="field-label">
              <text class="label-icon">🏷️</text>
              <text>分类</text>
            </view>
            <view class="field-tag category">{{parsedItem.category}}</view>
          </view>
          <view class="result-field half">
            <view class="field-label">
              <text class="label-icon">✨</text>
              <text>成色</text>
            </view>
            <view class="field-tag condition">{{parsedItem.condition}}</view>
          </view>
        </view>

        <!-- AI估价 -->
        <view class="result-field" wx:if="{{parsedItem.suggestedPrice}}">
          <view class="field-label">
            <text class="label-icon">💰</text>
            <text>AI估价</text>
          </view>
          <view class="price-tag">
            <text class="price-symbol">¥</text>
            <text class="price-number">{{parsedItem.suggestedPrice}}</text>
          </view>
        </view>

        <!-- 期望换到 -->
        <view class="result-field" wx:if="{{parsedItem.expectedItems && parsedItem.expectedItems.length > 0}}">
          <view class="field-label">
            <text class="label-icon">🔄</text>
            <text>期望换到</text>
          </view>
          <view class="tag-list">
            <view class="tag-item want" wx:for="{{parsedItem.expectedItems}}" wx:key="index">{{item}}</view>
          </view>
        </view>

        <!-- 智能标签 -->
        <view class="result-field" wx:if="{{parsedItem.tags && parsedItem.tags.length > 0}}">
          <view class="field-label">
            <text class="label-icon">🏷️</text>
            <text>智能标签</text>
          </view>
          <view class="tag-list">
            <view class="tag-item ai-tag" wx:for="{{parsedItem.tags}}" wx:key="index">{{item}}</view>
          </view>
        </view>

        <!-- 物品亮点 -->
        <view class="result-field" wx:if="{{parsedItem.keyFeatures && parsedItem.keyFeatures.length > 0}}">
          <view class="field-label">
            <text class="label-icon">💎</text>
            <text>物品亮点</text>
          </view>
          <view class="feature-list">
            <view class="feature-item" wx:for="{{parsedItem.keyFeatures}}" wx:key="index">
              <view class="feature-check">✓</view>
              <text>{{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="result-actions">
      <button class="action-btn secondary" bindtap="reset">
        <text class="btn-icon">↺</text>
        <text>重新输入</text>
      </button>
      <button class="action-btn primary" bindtap="goToPublish">
        <text class="btn-icon">🚀</text>
        <text>使用此信息发布</text>
      </button>
    </view>
  </view>
</view>
