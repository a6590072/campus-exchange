/* ============================================
   AI智能发布页面样式 - 未来科技感 v3.0
   ============================================ */

/* 动画关键帧 */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.05); opacity: 0.8; }
}

@keyframes ring {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.5); opacity: 0; }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-8rpx); }
}

/* 页面容器 */
.ai-publish-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  position: relative;
  overflow: hidden;
}

/* ========== 动态背景 ========== */
.dynamic-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

.bg-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 600rpx;
  background: linear-gradient(180deg, rgba(102, 126, 234, 0.3) 0%, transparent 100%);
}

.bg-pattern {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 20% 30%, rgba(102, 126, 234, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(118, 75, 162, 0.1) 0%, transparent 50%);
}

/* ========== 头部区域 ========== */
.header-section {
  position: relative;
  z-index: 10;
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.ai-avatar-container {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 30rpx;
}

.ai-avatar {
  position: relative;
  z-index: 10;
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 40rpx rgba(102, 126, 234, 0.5);
}

.avatar-icon {
  font-size: 72rpx;
  animation: float 3s ease-in-out infinite;
}

.avatar-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: 2rpx solid rgba(102, 126, 234, 0.5);
  border-radius: 50%;
  animation: ring 2s ease-out infinite;
}

.avatar-ring.r1 {
  width: 160rpx;
  height: 160rpx;
}

.avatar-ring.r2 {
  width: 180rpx;
  height: 180rpx;
  animation-delay: 0.5s;
}

.header-text {
  position: relative;
  z-index: 10;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ========== 输入区域 ========== */
.input-section {
  position: relative;
  z-index: 10;
  padding: 0 30rpx;
}

.input-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.input-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.input-icon {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  font-size: 28rpx;
}

.input-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.input-area {
  background: #f8fafc;
  border-radius: 20rpx;
  overflow: hidden;
}

.desc-input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #1f2937;
  line-height: 1.6;
  box-sizing: border-box;
}

.input-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #e2e8f0;
}

.voice-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #92400e;
  font-weight: 500;
  transition: all 0.3s ease;
}

.voice-btn:active {
  transform: scale(0.95);
}

.voice-icon {
  font-size: 28rpx;
}

.char-count {
  font-size: 24rpx;
  color: #94a3b8;
}

/* ========== 示例区域 ========== */
.examples-section {
  margin-bottom: 30rpx;
}

.examples-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.examples-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
}

.examples-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  white-space: nowrap;
}

.examples-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.example-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.example-card:active {
  background: rgba(255, 255, 255, 0.2);
  transform: translateX(8rpx);
}

.example-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  font-size: 32rpx;
}

.example-content {
  flex: 1;
}

.example-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.example-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* ========== 操作区域 ========== */
.action-section {
  padding: 0 20rpx;
}

.ai-parse-btn {
  position: relative;
  width: 100%;
  height: 108rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 54rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.ai-parse-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.5);
}

.ai-parse-btn:active.active {
  transform: translateY(2rpx) scale(0.98);
}

.btn-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.ai-parse-btn.active .btn-glow {
  opacity: 1;
  animation: pulse 2s ease-in-out infinite;
}

.btn-content {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.btn-icon-wrapper {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.btn-loading {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
}

.loading-dots .dot {
  width: 16rpx;
  height: 16rpx;
  background: #fff;
  border-radius: 50%;
  animation: typing 1.4s infinite;
}

.loading-dots .dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dots .dot:nth-child(3) {
  animation-delay: 0.4s;
}

.loading-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* ========== 结果区域 ========== */
.result-section {
  position: relative;
  z-index: 10;
  padding: 30rpx;
  animation: slideInUp 0.5s ease-out;
}

.result-card {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.success-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  border-radius: 28rpx;
}

.badge-icon {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #10b981;
  border-radius: 50%;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
}

.success-badge text:last-child {
  font-size: 26rpx;
  color: #047857;
  font-weight: 600;
}

.confidence-score {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #667eea;
}

.score-label {
  font-size: 22rpx;
  color: #94a3b8;
}

/* 结果字段 */
.result-content {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.result-field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.result-row {
  display: flex;
  gap: 24rpx;
}

.result-field.half {
  flex: 1;
}

.field-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #64748b;
}

.label-icon {
  font-size: 28rpx;
}

.field-value {
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
  padding: 16rpx 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
}

.field-value.highlight {
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  color: #4338ca;
  font-weight: 600;
}

.field-value.description {
  line-height: 1.6;
  color: #4b5563;
}

.field-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.field-tag.category {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  color: #1d4ed8;
}

.field-tag.condition {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #92400e;
}

.price-tag {
  display: inline-flex;
  align-items: baseline;
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #fecaca 0%, #fca5a5 100%);
  border-radius: 16rpx;
}

.price-symbol {
  font-size: 28rpx;
  font-weight: 700;
  color: #dc2626;
  margin-right: 4rpx;
}

.price-number {
  font-size: 40rpx;
  font-weight: 800;
  color: #dc2626;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-item.want {
  background: linear-gradient(135deg, #fce7f3 0%, #fbcfe8 100%);
  color: #be185d;
}

.tag-item.ai-tag {
  background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%);
  color: #6d28d9;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: #f0fdf4;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #166534;
}

.feature-check {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #22c55e;
  border-radius: 50%;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
}

/* 操作按钮 */
.result-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.action-btn.secondary:active {
  background: rgba(255, 255, 255, 0.2);
}

.action-btn.primary {
  flex: 1.5;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
}

.action-btn.primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.action-btn .btn-icon {
  font-size: 32rpx;
}
