/* ============================================
   AI估价页面样式 - 高端科技感 v3.0
   ============================================ */

/* 动画关键帧 */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.1); opacity: 0.4; }
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* 渐变色 */
.gradient-1 { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.gradient-2 { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
.gradient-3 { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }

/* 页面容器 */
.valuation-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ========== 头部背景 ========== */
.header-bg {
  position: relative;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 100rpx;
  overflow: hidden;
}

.header-content {
  position: relative;
  z-index: 10;
  text-align: center;
}

.ai-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.ai-avatar-icon {
  font-size: 60rpx;
  animation: float 3s ease-in-out infinite;
}

.ai-pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 140rpx;
  height: 140rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  animation: pulse 2s ease-out infinite;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 装饰圆圈 */
.header-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

.decoration-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.decoration-circle.c1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -100rpx;
}

.decoration-circle.c2 {
  width: 200rpx;
  height: 200rpx;
  bottom: 20rpx;
  left: -60rpx;
}

.decoration-circle.c3 {
  width: 150rpx;
  height: 150rpx;
  bottom: 60rpx;
  right: 60rpx;
}

/* ========== 表单区域 ========== */
.form-section {
  padding: 0 30rpx;
  margin-top: -60rpx;
  position: relative;
  z-index: 20;
}

.form-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.label-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  border-radius: 12rpx;
  font-size: 24rpx;
}

.required {
  color: #ef4444;
  margin-left: 4rpx;
}

/* 输入框 */
.input-wrapper {
  position: relative;
}

.form-input {
  width: 100%;
  height: 100rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #1f2937;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #667eea;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

/* 文本域 */
.textarea-wrapper {
  position: relative;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #1f2937;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

/* 选项网格 */
.options-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-chip {
  padding: 16rpx 28rpx;
  background: #f1f5f9;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #64748b;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  border: 2rpx solid transparent;
}

.option-chip.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.option-chip:active {
  transform: scale(0.95);
}

/* 成色滑块 */
.condition-slider {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.condition-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 12rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.condition-item.active {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-color: #f59e0b;
}

.condition-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #cbd5e1;
  transition: all 0.3s ease;
}

.condition-item.active .condition-dot {
  background: #f59e0b;
  box-shadow: 0 0 0 6rpx rgba(245, 158, 11, 0.2);
}

.condition-text {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

.condition-item.active .condition-text {
  color: #92400e;
}

/* ========== 操作区域 ========== */
.action-area {
  padding: 0 20rpx;
}

.evaluate-btn {
  width: 100%;
  height: 108rpx;
  background: #e2e8f0;
  border-radius: 54rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  margin-bottom: 20rpx;
}

.evaluate-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.4);
}

.evaluate-btn:active.active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.3);
}

.btn-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.btn-loading {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 30rpx;
  color: #fff;
}

.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.btn-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
}

/* ========== 结果区域 ========== */
.result-section {
  padding: 30rpx;
  animation: slideInUp 0.5s ease-out;
}

/* 价格结果卡片 */
.price-result-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.3);
}

.price-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.price-title {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.confidence-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #fff;
}

.confidence-badge.high {
  background: rgba(16, 185, 129, 0.3);
}

.confidence-badge.medium {
  background: rgba(245, 158, 11, 0.3);
}

.confidence-badge.low {
  background: rgba(239, 68, 68, 0.3);
}

.badge-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #fff;
}

.price-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 40rpx;
}

.price-currency {
  font-size: 48rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.9);
  margin-right: 8rpx;
}

.price-value {
  font-size: 96rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: -2rpx;
}

/* 价格区间条 */
.price-range-bar {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 30rpx 24rpx 20rpx;
}

.range-track {
  position: relative;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
  margin-bottom: 50rpx;
}

.range-fill {
  position: absolute;
  top: 0;
  height: 100%;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 4rpx;
}

.range-marker {
  position: absolute;
  top: -10rpx;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
}

.range-marker.current .marker-dot {
  width: 28rpx;
  height: 28rpx;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  border: 4rpx solid #667eea;
}

.marker-label {
  position: absolute;
  top: 36rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  white-space: nowrap;
}

.range-labels {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 16rpx;
}

/* 结果卡片 */
.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  animation: slideInUp 0.5s ease-out forwards;
  opacity: 0;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.header-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.card-body {
  padding-left: 68rpx;
}

.analysis-text {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.7;
}

/* 因素列表 */
.factor-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.factor-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  animation: slideInUp 0.4s ease-out forwards;
  opacity: 0;
}

.factor-num {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  flex-shrink: 0;
}

.factor-text {
  flex: 1;
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.5;
  padding-top: 4rpx;
}

/* 建议卡片 */
.tips-card {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 20%, #fff 20%);
}

.tips-content {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tips-icon {
  font-size: 40rpx;
}

.tips-text {
  flex: 1;
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.7;
}

/* 操作按钮 */
.result-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.action-btn.secondary {
  background: #f1f5f9;
  color: #64748b;
}

.action-btn.secondary:active {
  background: #e2e8f0;
}

.action-btn.primary {
  flex: 1.5;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.35);
}

.action-btn.primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.25);
}
