<view class="container container-safe">
  <!-- 搜索栏 -->
  <view class="search-header">
    <view class="search-input-wrapper">
      <text class="icon">🔍</text>
      <input class="search-input" 
             placeholder="{{placeholder}}" 
             value="{{keyword}}"
             bindinput="onInput"
             bindconfirm="doSearch"
             focus="{{true}}"/>
      <text class="clear-btn" wx:if="{{keyword}}" bindtap="clearSearch">✕</text>
    </view>
    <text class="cancel-btn" bindtap="goBack">取消</text>
  </view>

  <!-- 搜索历史 -->
  <view class="search-history" wx:if="{{!keyword && history.length > 0}}">
    <view class="section-header">
      <text class="title">搜索历史</text>
      <text class="clear" bindtap="clearHistory">清空</text>
    </view>
    <view class="history-list">
      <text class="history-item" wx:for="{{history}}" wx:key="*this" bindtap="searchFromHistory" data-keyword="{{item}}">{{item}}</text>
    </view>
  </view>

  <!-- 热门搜索 -->
  <view class="hot-search" wx:if="{{!keyword}}">
    <view class="section-header">
      <text class="title">热门搜索</text>
    </view>
    <view class="hot-list">
      <view class="hot-item {{index < 3 ? 'top' : ''}}" wx:for="{{hotKeywords}}" wx:key="*this" bindtap="searchFromHistory" data-keyword="{{item}}">
        <text class="rank">{{index + 1}}</text>
        <text class="keyword">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="search-results" wx:if="{{keyword}}">
    <view class="filter-bar">
      <view class="filter-item {{currentFilter === 'all' ? 'active' : ''}}" bindtap="setFilter" data-filter="all">综合</view>
      <view class="filter-item {{currentFilter === 'newest' ? 'active' : ''}}" bindtap="setFilter" data-filter="newest">最新</view>
      <view class="filter-item {{currentFilter === 'nearest' ? 'active' : ''}}" bindtap="setFilter" data-filter="nearest">最近</view>
    </view>

    <!-- 物品列表 -->
    <view class="item-list" wx:if="{{items.length > 0}}">
      <view class="item-card" wx:for="{{items}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image class="item-image" src="{{item.images[0] || '/images/default/item.svg'}}" mode="aspectFill"/>
        <view class="item-info">
          <text class="item-title">{{item.title}}</text>
          <view class="item-tags">
            <text class="tag condition">{{item.condition}}</text>
            <text class="tag category">{{item.category_name}}</text>
          </view>
          <view class="item-footer">
            <view class="user-info">
              <image class="avatar-small" src="{{item.owner_avatar || '/images/default/avatar.svg'}}"/>
              <text class="nickname">{{item.owner_nickname}}</text>
            </view>
            <text class="time">{{item.created_at}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && items.length === 0}}">
      <text class="empty-icon">🔍</text>
      <text class="empty-title">未找到相关物品</text>
      <text class="empty-desc">换个关键词试试</text>
    </view>
  </view>
</view>
