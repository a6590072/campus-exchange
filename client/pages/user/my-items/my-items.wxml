<view class="container container-safe">
  <!-- 标签切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'selling' ? 'active' : ''}}" bindtap="switchTab" data-tab="selling">
      出售中
      <text wx:if="{{counts.selling > 0}}" class="badge">{{counts.selling}}</text>
    </view>
    <view class="tab-item {{activeTab === 'exchanged' ? 'active' : ''}}" bindtap="switchTab" data-tab="exchanged">
      已换出
      <text wx:if="{{counts.exchanged > 0}}" class="badge">{{counts.exchanged}}</text>
    </view>
    <view class="tab-item {{activeTab === 'offline' ? 'active' : ''}}" bindtap="switchTab" data-tab="offline">
      已下架
      <text wx:if="{{counts.offline > 0}}" class="badge">{{counts.offline}}</text>
    </view>
  </view>

  <!-- 物品列表 -->
  <view class="item-list" wx:if="{{items.length > 0}}">
    <view class="item-card" wx:for="{{items}}" wx:key="id">
      <image class="item-image" src="{{item.images[0] || '/images/default/item.svg'}}" mode="aspectFill" bindtap="goToDetail" data-id="{{item.id}}"/>
      <view class="item-info" bindtap="goToDetail" data-id="{{item.id}}">
        <text class="item-title">{{item.title}}</text>
        <view class="item-tags">
          <text class="tag condition">{{item.condition}}</text>
          <text class="tag status {{item.status}}">{{item.statusText}}</text>
        </view>
        <text class="item-time">{{item.created_at}}</text>
      </view>
      <view class="item-actions">
        <view class="action-btn edit" bindtap="editItem" data-id="{{item.id}}">编辑</view>
        <view class="action-btn delete" bindtap="deleteItem" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && items.length === 0}}">
    <text class="empty-icon">📦</text>
    <text class="empty-title">暂无{{activeTabText}}</text>
    <text class="empty-desc">{{activeTab === 'selling' ? '快去发布你的闲置物品吧~' : '还没有相关物品'}}</text>
    <view class="btn btn-primary mt-4" wx:if="{{activeTab === 'selling'}}" bindtap="goToPublish">去发布</view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
