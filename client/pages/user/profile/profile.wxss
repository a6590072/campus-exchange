/* ============================================
   个人中心样式 - 高端沉浸式体验 v3.0
   ============================================ */

/* 动画关键帧 */
@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(5deg); }
}

@keyframes pulse-ring {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.3); opacity: 0; }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes blob {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(30rpx, -50rpx) scale(1.1); }
  66% { transform: translate(-20rpx, 20rpx) scale(0.9); }
}

/* 渐变色定义 */
.gradient-1 { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
.gradient-2 { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
.gradient-3 { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
.gradient-4 { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }

/* 页面容器 */
.profile-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  position: relative;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 状态栏占位 */
.status-bar {
  width: 100%;
  background: transparent;
  position: relative;
  z-index: 10;
}

/* ========== 动态背景 ========== */
.dynamic-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 600rpx;
  overflow: hidden;
  z-index: 0;
}

.bg-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
}

.bg-pattern {
  position: absolute;
  inset: 0;
  background-image: 
    radial-gradient(circle at 20% 30%, rgba(255,255,255,0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(255,255,255,0.1) 0%, transparent 50%);
}

.bg-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
  opacity: 0.5;
  animation: blob 10s infinite;
}

.blob-1 {
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.3);
  top: -100rpx;
  right: -50rpx;
  animation-delay: 0s;
}

.blob-2 {
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.2);
  bottom: 50rpx;
  left: -50rpx;
  animation-delay: -5s;
}

/* ========== 用户信息卡片 ========== */
.user-card {
  position: relative;
  margin: 40rpx 30rpx 30rpx;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
  box-shadow: 0 20rpx 60rpx rgba(102, 126, 234, 0.2);
  animation: fadeInUp 0.6s ease-out;
  z-index: 1;
}

.user-avatar-wrapper {
  position: relative;
  flex-shrink: 0;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

.avatar-ring {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.3);
  border-radius: 50%;
  animation: pulse-ring 2s ease-out infinite;
}

.verified-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.verified-badge text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

/* 登录提示 */
.login-hint {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.3);
  animation: fadeInUp 0.5s ease-out;
}

.login-hint text {
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
}

.user-name.login-text {
  color: #6366f1;
  position: relative;
  display: inline-block;
}

.user-name.login-text::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 2rpx;
  opacity: 0.5;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #1f2937;
  margin-bottom: 16rpx;
  display: block;
}

.user-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.user-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.user-tag.school {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  color: #1e40af;
}

.user-tag.verify {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #065f46;
}

.user-tag.level {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #92400e;
}

.tag-icon {
  font-size: 20rpx;
}

.user-intro {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.5;
  display: block;
}

.settings-btn {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 72rpx;
  height: 72rpx;
  background: rgba(243, 244, 246, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  transition: all 0.3s ease;
}

.settings-btn:active {
  background: rgba(229, 231, 235, 1);
  transform: rotate(30deg);
}

/* ========== 数据统计卡片 ========== */
.stats-card {
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  animation: fadeInUp 0.6s ease-out 0.1s forwards;
  opacity: 0;
  position: relative;
  z-index: 1;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.stat-value-wrapper {
  position: relative;
  margin-bottom: 12rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #1f2937;
  position: relative;
  z-index: 1;
}

.stat-num.credit {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 60rpx;
  height: 60rpx;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.2) 0%, transparent 70%);
  border-radius: 50%;
  z-index: 0;
}

.stat-glow.credit {
  background: radial-gradient(circle, rgba(245, 158, 11, 0.2) 0%, transparent 70%);
}

.stat-label {
  font-size: 24rpx;
  color: #6b7280;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent 0%, #e5e7eb 50%, transparent 100%);
}

/* ========== AI功能区 ========== */
.ai-section {
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  animation: fadeInUp 0.6s ease-out 0.2s forwards;
  opacity: 0;
  position: relative;
  z-index: 1;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.ai-grid {
  display: flex;
  justify-content: space-between;
}

.ai-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.ai-item:active {
  background: #f9fafb;
  transform: scale(0.98);
}

.ai-icon-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.ai-pulse {
  position: absolute;
  inset: -4rpx;
  border-radius: 28rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.3);
  animation: pulse-ring 2s ease-out infinite;
}

.ai-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

.ai-desc {
  font-size: 22rpx;
  color: #9ca3af;
}

/* ========== 功能菜单 ========== */
.menu-section {
  margin: 0 30rpx 30rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  animation: fadeInUp 0.6s ease-out 0.3s forwards;
  opacity: 0;
  position: relative;
  z-index: 1;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.menu-item:not(:last-child) {
  border-bottom: 1rpx solid #f3f4f6;
}

.menu-item:active {
  background: #f9fafb;
}

.menu-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.menu-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.menu-desc {
  font-size: 24rpx;
  color: #9ca3af;
}

.menu-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: #fef3c7;
  color: #92400e;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: 20rpx;
  margin-top: 4rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #d1d5db;
  margin-left: 16rpx;
}

.safe-area-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
