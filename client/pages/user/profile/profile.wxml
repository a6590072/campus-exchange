<view class="profile-container">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 动态背景 -->
  <view class="dynamic-bg">
    <view class="bg-gradient"></view>
    <view class="bg-pattern"></view>
    <view class="bg-blob blob-1"></view>
    <view class="bg-blob blob-2"></view>
  </view>

  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-avatar-wrapper" bindtap="{{isLoggedIn ? '' : 'wechatLogin'}}">
      <image class="user-avatar" src="{{userInfo.avatar_url || '/images/default/avatar.svg'}}" mode="aspectFill"/>
      <view class="avatar-ring"></view>
      <view class="verified-badge" wx:if="{{userInfo.is_verified}}">
        <text>✓</text>
      </view>
      <view class="login-hint" wx:if="{{!isLoggedIn}}">
        <text>点击登录</text>
      </view>
    </view>
    <view class="user-info">
      <text class="user-name {{!isLoggedIn ? 'login-text' : ''}}" bindtap="{{isLoggedIn ? '' : 'wechatLogin'}}">{{userInfo.nickname || '未登录'}}</text>
      <view class="user-tags">
        <view class="user-tag school" wx:if="{{userInfo.school_name}}">
          <text class="tag-icon">🎓</text>
          <text>{{userInfo.school_name}}</text>
        </view>
        <view class="user-tag verify" wx:if="{{userInfo.is_verified}}">
          <text class="tag-icon">✓</text>
          <text>已认证</text>
        </view>
        <view class="user-tag level" wx:if="{{isLoggedIn}}">
          <text class="tag-icon">⭐</text>
          <text>LV.{{Math.floor((stats.exchangeCount || 0) / 5) + 1}}</text>
        </view>
      </view>
      <text class="user-intro" wx:if="{{userInfo.introduction}}">{{userInfo.introduction}}</text>
      <text class="user-intro" wx:else>让闲置物品流动起来，开启校园交换之旅</text>
    </view>
    <view class="settings-btn" bindtap="goToSettings" wx:if="{{isLoggedIn}}">
      <text>⚙️</text>
    </view>
  </view>

  <!-- 数据统计卡片 -->
  <view class="stats-card">
    <view class="stat-item" bindtap="goToMyItems">
      <view class="stat-value-wrapper">
        <text class="stat-num">{{stats.itemCount || 0}}</text>
        <view class="stat-glow"></view>
      </view>
      <text class="stat-label">发布</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goToMyExchanges">
      <view class="stat-value-wrapper">
        <text class="stat-num">{{stats.exchangeCount || 0}}</text>
        <view class="stat-glow"></view>
      </view>
      <text class="stat-label">交换</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goToFavorites">
      <view class="stat-value-wrapper">
        <text class="stat-num">{{stats.favoriteCount || 0}}</text>
        <view class="stat-glow"></view>
      </view>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-value-wrapper">
        <text class="stat-num credit">{{stats.creditScore || 100}}</text>
        <view class="stat-glow credit"></view>
      </view>
      <text class="stat-label">信用分</text>
    </view>
  </view>

  <!-- AI功能区 -->
  <view class="ai-section">
    <view class="section-header">
      <view class="section-title-wrapper">
        <view class="section-icon">🤖</view>
        <text class="section-title">AI智能服务</text>
      </view>
    </view>
    <view class="ai-grid">
      <view class="ai-item" bindtap="goToValuation">
        <view class="ai-icon-wrapper gradient-1">
          <text class="ai-icon">💰</text>
          <view class="ai-pulse"></view>
        </view>
        <text class="ai-name">AI估价</text>
        <text class="ai-desc">智能定价</text>
      </view>
      <view class="ai-item" bindtap="goToAIPublish">
        <view class="ai-icon-wrapper gradient-2">
          <text class="ai-icon">✨</text>
          <view class="ai-pulse"></view>
        </view>
        <text class="ai-name">AI发布</text>
        <text class="ai-desc">语音发布</text>
      </view>
      <view class="ai-item" bindtap="goToAIAssistant">
        <view class="ai-icon-wrapper gradient-3">
          <text class="ai-icon">💬</text>
          <view class="ai-pulse"></view>
        </view>
        <text class="ai-name">AI助手</text>
        <text class="ai-desc">24小时在线</text>
      </view>
      <view class="ai-item" bindtap="goToSmartMatch">
        <view class="ai-icon-wrapper gradient-4">
          <text class="ai-icon">🎯</text>
          <view class="ai-pulse"></view>
        </view>
        <text class="ai-name">智能匹配</text>
        <text class="ai-desc">精准推荐</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-title">我的物品</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToMyItems">
        <view class="menu-icon-wrapper" style="background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%);">
          <text class="menu-icon">📦</text>
        </view>
        <view class="menu-content">
          <text class="menu-text">我的发布</text>
          <text class="menu-desc">管理已发布的物品</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="goToMyExchanges">
        <view class="menu-icon-wrapper" style="background: linear-gradient(135deg, #F0FDF4 0%, #DCFCE7 100%);">
          <text class="menu-icon">🔄</text>
        </view>
        <view class="menu-content">
          <text class="menu-text">换物记录</text>
          <text class="menu-desc">查看交换历史</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="goToFavorites">
        <view class="menu-icon-wrapper" style="background: linear-gradient(135deg, #FDF2F8 0%, #FCE7F3 100%);">
          <text class="menu-icon">❤️</text>
        </view>
        <view class="menu-content">
          <text class="menu-text">我的收藏</text>
          <text class="menu-desc">收藏的心动好物</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 设置菜单 -->
  <view class="menu-section">
    <view class="menu-title">系统设置</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToVerification" wx:if="{{!userInfo.is_verified}}">
        <view class="menu-icon-wrapper" style="background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);">
          <text class="menu-icon">🎓</text>
        </view>
        <view class="menu-content">
          <text class="menu-text">学生认证</text>
          <text class="menu-badge">未认证</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="contactSupport">
        <view class="menu-icon-wrapper" style="background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);">
          <text class="menu-icon">💬</text>
        </view>
        <view class="menu-content">
          <text class="menu-text">联系客服</text>
          <text class="menu-desc">遇到问题找我们</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="showAbout">
        <view class="menu-icon-wrapper" style="background: linear-gradient(135deg, #F3F4F6 0%, #E5E7EB 100%);">
          <text class="menu-icon">ℹ️</text>
        </view>
        <view class="menu-content">
          <text class="menu-text">关于我们</text>
          <text class="menu-desc">v1.0.0</text>
        </view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>
