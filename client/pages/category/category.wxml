<view class="container container-safe">
  <!-- 搜索栏 -->
  <view class="search-bar" bindtap="goToSearch">
    <text class="icon">🔍</text>
    <text class="placeholder">搜索物品、品牌、型号...</text>
  </view>

  <!-- 分类列表 -->
  <view class="category-list">
    <view class="category-card" wx:for="{{categories}}" wx:key="id" bindtap="goToCategoryItems" data-id="{{item.id}}">
      <view class="category-icon" style="background: {{item.bgColor}}">
        <text>{{item.icon}}</text>
      </view>
      <view class="category-info">
        <text class="category-name">{{item.name}}</text>
        <text class="category-count">{{item.count || 0}}件物品</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
