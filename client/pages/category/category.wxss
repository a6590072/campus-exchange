/* ============================================
   分类页面样式 - 清新校园风 v2.0
   ============================================ */

/* ---------- 搜索栏 ---------- */
.search-bar {
  display: flex;
  align-items: center;
  height: 88rpx;
  background: var(--surface);
  border-radius: var(--radius-full);
  padding: 0 var(--space-4);
  margin-bottom: var(--space-4);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
  transition: all var(--transition-fast);
}

.search-bar:active {
  box-shadow: var(--shadow-md);
  border-color: var(--primary-soft);
}

.search-bar .icon {
  font-size: 32rpx;
  margin-right: var(--space-2);
  color: var(--text-tertiary);
}

.search-bar .placeholder {
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* ---------- 分类列表 ---------- */
.category-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

/* ---------- 分类卡片 ---------- */
.category-card {
  display: flex;
  align-items: center;
  background: var(--surface);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-light);
  transition: all var(--transition-base);
}

.category-card:active {
  transform: translateX(8rpx);
  box-shadow: var(--shadow-lg);
}

.category-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: var(--space-3);
  box-shadow: var(--shadow-sm);
  transition: transform var(--transition-fast);
}

.category-card:active .category-icon {
  transform: scale(1.1) rotate(-5deg);
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-1);
}

.category-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.category-arrow {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--background);
  border-radius: 50%;
  font-size: 32rpx;
  color: var(--text-tertiary);
  transition: all var(--transition-fast);
}

.category-card:active .category-arrow {
  background: var(--primary-soft);
  color: var(--primary);
  transform: translateX(4rpx);
}

/* ---------- 热门分类网格 ---------- */
.hot-categories {
  margin-bottom: var(--space-4);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-3);
  display: flex;
  align-items: center;
  gap: var(--space-1);
}

.hot-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-3);
}

.hot-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-3);
  background: var(--surface);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
  transition: all var(--transition-fast);
}

.hot-item:active {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-md);
}

.hot-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: var(--space-2);
  box-shadow: var(--shadow-sm);
}

.hot-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* ---------- 分类标签云 ---------- */
.tag-cloud {
  margin-bottom: var(--space-4);
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.tag-item {
  padding: var(--space-2) var(--space-3);
  background: var(--surface);
  border-radius: var(--radius-full);
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 1rpx solid var(--border);
  transition: all var(--transition-fast);
}

.tag-item:active {
  background: var(--primary-soft);
  border-color: var(--primary-light);
  color: var(--primary);
}

.tag-item.active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
  box-shadow: 0 4rpx 12rpx rgba(79, 70, 229, 0.3);
}

/* ---------- 推荐分类 ---------- */
.recommend-section {
  margin-bottom: var(--space-4);
}

.recommend-card {
  background: linear-gradient(135deg, var(--primary-soft) 0%, #E0E7FF 100%);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  display: flex;
  align-items: center;
  gap: var(--space-3);
  border: 1rpx solid rgba(79, 70, 229, 0.1);
}

.recommend-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  box-shadow: var(--shadow-md);
}

.recommend-content {
  flex: 1;
}

.recommend-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-1);
}

.recommend-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.recommend-btn {
  padding: var(--space-2) var(--space-3);
  background: var(--primary);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 12rpx rgba(79, 70, 229, 0.3);
}

/* ---------- 空状态 ---------- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-8) var(--space-4);
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--space-4);
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}
