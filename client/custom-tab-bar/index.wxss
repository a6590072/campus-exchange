/* ============================================
   高端自定义TabBar样式
   设计特点：
   - 毛玻璃效果背景
   - 发光动效
   - 中间按钮悬浮设计
   - 点击波纹反馈
   - 平滑过渡动画
   ============================================ */

/* TabBar容器 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(120rpx + env(safe-area-inset-bottom));
  z-index: 9999;
  display: flex;
  flex-direction: column;
}

/* 背景层 - 毛玻璃效果 */
.tab-bar-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 -4rpx 30rpx rgba(0, 0, 0, 0.05);
}

/* 顶部发光效果 */
.tab-bar-glow {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(99, 102, 241, 0.3) 20%,
    rgba(99, 102, 241, 0.6) 50%,
    rgba(99, 102, 241, 0.3) 80%,
    transparent 100%
  );
}

/* 内容层 */
.tab-bar-content {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-around;
  padding-top: 16rpx;
}

/* Tab项 */
.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  height: 100rpx;
  position: relative;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.tab-bar-item:active {
  transform: scale(0.95);
}

/* 图标包装器 */
.icon-wrapper {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 图标背景 */
.icon-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: transparent;
  transition: all 0.3s ease;
}

.tab-bar-item.active .icon-bg {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(99, 102, 241, 0.05) 100%);
  transform: scale(1.2);
}

/* 图标内容 */
.icon-content {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 图标字体 */
.iconfont {
  font-size: 44rpx;
  color: #94A3B8;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.iconfont.active {
  color: #6366F1;
  transform: translateY(-4rpx);
}

/* 波纹效果 */
.ripple {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx solid rgba(99, 102, 241, 0.3);
  animation: ripple-effect 0.6s ease-out;
  pointer-events: none;
}

@keyframes ripple-effect {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  100% {
    transform: scale(1.8);
    opacity: 0;
  }
}

/* 文字 */
.tab-text {
  font-size: 20rpx;
  color: #94A3B8;
  margin-top: 8rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.tab-text.active {
  color: #6366F1;
  font-weight: 600;
  transform: scale(1.05);
}

/* ============ 中间发布按钮特殊样式 ============ */

/* 中间项容器 */
.tab-bar-item.center {
  margin-top: -30rpx;
}

/* 中间按钮包装器 */
.center-btn-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 中间按钮发光背景 */
.center-btn-glow {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(99, 102, 241, 0.2) 0%, transparent 70%);
  animation: glow-pulse 2s ease-in-out infinite;
}

@keyframes glow-pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.5;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.8;
  }
}

/* 中间按钮 */
.center-btn {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 50%, #A855F7 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 
    0 8rpx 24rpx rgba(99, 102, 241, 0.4),
    0 4rpx 8rpx rgba(99, 102, 241, 0.2),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 10;
}

.center-btn::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 40%;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, transparent 100%);
}

.center-btn-wrapper:active .center-btn {
  transform: scale(0.92);
  box-shadow: 
    0 4rpx 12rpx rgba(99, 102, 241, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.2);
}

.center-btn .iconfont {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* 中间按钮波纹 */
.center-ripple {
  position: absolute;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(99, 102, 241, 0.3);
  animation: center-ripple 1.5s ease-out infinite;
  pointer-events: none;
}

@keyframes center-ripple {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

/* 中间按钮文字 */
.center-text {
  margin-top: 12rpx;
  color: #6366F1;
  font-weight: 600;
}

/* 安全区域适配 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.85);
}

/* ============ 图标字体定义（使用系统emoji作为fallback） ============ */
/* 实际项目中建议引入iconfont图标库 */
.icon-home::before {
  content: '\1F3E0';
}

.icon-category::before {
  content: '\1F4C4';
}

.icon-publish::before {
  content: '\2795';
}

.icon-message::before {
  content: '\1F4AC';
}

.icon-profile::before {
  content: '\1F464';
}