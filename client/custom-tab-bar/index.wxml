<view class="tab-bar">
  <view class="tab-bar-bg">
    <view class="tab-bar-glow"></view>
  </view>
  
  <view class="tab-bar-content">
    <view 
      wx:for="{{list}}" 
      wx:key="index"
      class="tab-bar-item {{selected === index ? 'active' : ''}} {{index === 2 ? 'center' : ''}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <!-- 普通tab -->
      <block wx:if="{{index !== 2}}">
        <view class="icon-wrapper">
          <view class="icon-bg"></view>
          <view class="icon-content">
            <text class="iconfont {{item.icon}} {{selected === index ? 'active' : ''}}"></text>
          </view>
          <view class="ripple" wx:if="{{selected === index}}"></view>
        </view>
        <text class="tab-text {{selected === index ? 'active' : ''}}">{{item.text}}</text>
      </block>
      
      <!-- 中间发布按钮 -->
      <block wx:if="{{index === 2}}">
        <view class="center-btn-wrapper">
          <view class="center-btn-glow"></view>
          <view class="center-btn">
            <text class="iconfont {{item.icon}}"></text>
          </view>
          <view class="center-ripple"></view>
        </view>
        <text class="tab-text center-text">{{item.text}}</text>
      </block>
    </view>
  </view>
  
  <!-- 安全区域适配 -->
  <view class="safe-area-bottom"></view>
</view>