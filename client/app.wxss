/* ============================================
   物的第二站 - 全新设计系统 v2.0
   风格：清新校园风 · 现代简约 · 活力年轻
   ============================================ */

/* ---------- CSS 变量定义 ---------- */
page {
  /* 主品牌色 - 靛蓝系 */
  --primary: #4F46E5;
  --primary-light: #818CF8;
  --primary-lighter: #A5B4FC;
  --primary-dark: #4338CA;
  --primary-soft: #EEF2FF;
  --primary-glow: rgba(79, 70, 229, 0.15);
  
  /* 强调色 - 琥珀系 */
  --accent: #F59E0B;
  --accent-light: #FBBF24;
  --accent-soft: #FEF3C7;
  
  /* 功能色 */
  --success: #10B981;
  --success-soft: #D1FAE5;
  --warning: #F59E0B;
  --warning-soft: #FEF3C7;
  --error: #EF4444;
  --error-soft: #FEE2E2;
  --info: #3B82F6;
  --info-soft: #DBEAFE;
  
  /* 中性色 */
  --background: #F8FAFC;
  --surface: #FFFFFF;
  --surface-hover: #FAFBFC;
  --surface-pressed: #F1F5F9;
  --border: #E2E8F0;
  --border-light: #F1F5F9;
  --divider: #F1F5F9;
  
  /* 文本色 */
  --text-primary: #0F172A;
  --text-secondary: #475569;
  --text-tertiary: #94A3B8;
  --text-quaternary: #CBD5E1;
  --text-inverse: #FFFFFF;
  
  /* 间距系统 - 8pt 网格 */
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 48rpx;
  --space-6: 64rpx;
  --space-8: 96rpx;
  --space-10: 128rpx;
  
  /* 圆角系统 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 20rpx;
  --radius-xl: 28rpx;
  --radius-2xl: 36rpx;
  --radius-full: 9999rpx;
  
  /* 阴影系统 */
  --shadow-sm: 0 1rpx 2rpx 0 rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.08), 0 2rpx 4rpx -2rpx rgba(0, 0, 0, 0.04);
  --shadow-lg: 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.08), 0 4rpx 6rpx -4rpx rgba(0, 0, 0, 0.04);
  --shadow-xl: 0 20rpx 25rpx -5rpx rgba(0, 0, 0, 0.08), 0 8rpx 10rpx -6rpx rgba(0, 0, 0, 0.04);
  --shadow-glow: 0 0 30rpx var(--primary-glow);
  --shadow-inner: inset 0 2rpx 4rpx 0 rgba(0, 0, 0, 0.04);
  
  /* 动效 */
  --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
  --transition-base: 250ms cubic-bezier(0.4, 0, 0.2, 1);
  --transition-slow: 350ms cubic-bezier(0.4, 0, 0.2, 1);
  --transition-bounce: 500ms cubic-bezier(0.68, -0.55, 0.265, 1.55);
  
  /* 基础样式 */
  background-color: var(--background);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ---------- 通用布局 ---------- */
.container {
  padding: var(--space-4);
  min-height: 100vh;
  box-sizing: border-box;
}

.container-safe {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.container-narrow {
  padding: var(--space-3);
}

/* ---------- 卡片组件 ---------- */
.card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  transition: transform var(--transition-base), box-shadow var(--transition-base);
}

.card-hover:active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-lg);
}

.card-flat {
  background: var(--surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border-light);
}

.card-elevated {
  background: var(--surface);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-lg);
}

.card-glass {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-xl);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

/* ---------- 按钮组件 ---------- */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  padding: 0 var(--space-5);
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  transition: all var(--transition-base);
  position: relative;
  overflow: hidden;
}

.btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.15) 0%, transparent 100%);
  pointer-events: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: var(--text-inverse);
  box-shadow: 0 4rpx 14rpx rgba(79, 70, 229, 0.35);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(79, 70, 229, 0.25);
}

.btn-secondary {
  background: var(--surface);
  color: var(--primary);
  border: 2rpx solid var(--primary-soft);
}

.btn-secondary:active {
  background: var(--primary-soft);
}

.btn-accent {
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-light) 100%);
  color: var(--text-inverse);
  box-shadow: 0 4rpx 14rpx rgba(245, 158, 11, 0.35);
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
}

.btn-ghost:active {
  background: var(--surface-hover);
}

.btn-sm {
  height: 72rpx;
  padding: 0 var(--space-4);
  font-size: 26rpx;
  border-radius: var(--radius-md);
}

.btn-lg {
  height: 108rpx;
  padding: 0 var(--space-6);
  font-size: 32rpx;
  border-radius: var(--radius-xl);
}

.btn-round {
  border-radius: var(--radius-full);
}

.btn-block {
  width: 100%;
}

/* ---------- 表单组件 ---------- */
.input {
  height: 96rpx;
  padding: 0 var(--space-4);
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--text-primary);
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}

.input:focus {
  border-color: var(--primary-light);
  box-shadow: 0 0 0 4rpx var(--primary-glow);
}

.input::placeholder {
  color: var(--text-tertiary);
}

.textarea {
  min-height: 200rpx;
  padding: var(--space-3);
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  line-height: 1.6;
}

/* ---------- 标签组件 ---------- */
.tag {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 var(--space-2);
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background: var(--primary-soft);
  color: var(--primary);
}

.tag-accent {
  background: var(--accent-soft);
  color: #92400E;
}

.tag-success {
  background: var(--success-soft);
  color: #065F46;
}

.tag-outline {
  background: transparent;
  border: 1rpx solid var(--border);
  color: var(--text-secondary);
}

/* ---------- 分隔线 ---------- */
.divider {
  height: 1rpx;
  background: var(--divider);
  margin: var(--space-4) 0;
}

.divider-vertical {
  width: 1rpx;
  height: 100%;
  background: var(--divider);
}

/* ---------- 空状态 ---------- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-8) var(--space-4);
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--space-4);
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* ---------- 加载状态 ---------- */
.skeleton {
  background: linear-gradient(90deg, var(--border-light) 25%, var(--border) 50%, var(--border-light) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-md);
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ---------- 动画 ---------- */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { 
    opacity: 0;
    transform: translateY(30rpx);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes scaleIn {
  from { 
    opacity: 0;
    transform: scale(0.9);
  }
  to { 
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.animate-fade-in {
  animation: fadeIn var(--transition-base) ease-out;
}

.animate-slide-up {
  animation: slideUp var(--transition-base) ease-out;
}

.animate-scale-in {
  animation: scaleIn var(--transition-base) ease-out;
}

/* ---------- 工具类 ---------- */
.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-tertiary { color: var(--text-tertiary); }
.text-brand { color: var(--primary); }
.text-accent { color: var(--accent); }
.text-success { color: var(--success); }
.text-error { color: var(--error); }

.text-xs { font-size: 22rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 40rpx; }

.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.flex-1 { flex: 1; }
.gap-1 { gap: var(--space-1); }
.gap-2 { gap: var(--space-2); }
.gap-3 { gap: var(--space-3); }
.gap-4 { gap: var(--space-4); }

.mt-1 { margin-top: var(--space-1); }
.mt-2 { margin-top: var(--space-2); }
.mt-3 { margin-top: var(--space-3); }
.mt-4 { margin-top: var(--space-4); }
.mb-1 { margin-bottom: var(--space-1); }
.mb-2 { margin-bottom: var(--space-2); }
.mb-3 { margin-bottom: var(--space-3); }
.mb-4 { margin-bottom: var(--space-4); }

.p-3 { padding: var(--space-3); }
.p-4 { padding: var(--space-4); }

.rounded-lg { border-radius: var(--radius-lg); }
.rounded-xl { border-radius: var(--radius-xl); }
.rounded-full { border-radius: var(--radius-full); }

.shadow-sm { box-shadow: var(--shadow-sm); }
.shadow-md { box-shadow: var(--shadow-md); }
.shadow-lg { box-shadow: var(--shadow-lg); }

.overflow-hidden { overflow: hidden; }
.relative { position: relative; }
.absolute { position: absolute; }
