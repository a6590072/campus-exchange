# 服务器配置
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# 数据库配置 - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=campus_exchange
DB_USER=postgres
DB_PASSWORD=your_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 微信小程序配置
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret
WECHAT_MCH_ID=your_merchant_id
WECHAT_API_KEY=your_api_key

# 阿里云百炼AI配置
DASHSCOPE_API_KEY=sk-sp-80d30ee1dfc44b72bd7b456d110b1727
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
DASHSCOPE_MODEL=kimi-k2.5

# 阿里云OSS配置
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=campus-exchange
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_CDN_DOMAIN=https://cdn.yourdomain.com

# 阿里云短信配置
SMS_ACCESS_KEY_ID=your_sms_access_key
SMS_ACCESS_KEY_SECRET=your_sms_secret
SMS_SIGN_NAME=换换校园
SMS_TEMPLATE_CODE=SMS_12345678

# 文件上传配置
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/app.log

# 安全配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=12

# 功能开关
ENABLE_AI_VALUATION=true
ENABLE_AI_MATCH=true
ENABLE_ESCROW=true
ENABLE_REALTIME_CHAT=true
